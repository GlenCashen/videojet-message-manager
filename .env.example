# Videojet Message Manager configuration example.
# Copy this file to .env for local development and fill in site-specific values.
# Do not commit real .env files or secrets.

# Main server
NODE_ENV=development
PORT=8080
DB_PATH=data/videojet.db
SESSION_SECRET=
TRUST_PROXY=false

# First-run admin bootstrap. Remove these after the first admin user has signed in.
BOOTSTRAP_ADMIN_USERNAME=
BOOTSTRAP_ADMIN_PASSWORD=
BOOTSTRAP_ADMIN_DISPLAY_NAME=

# Development access helpers. Keep disabled in production.
ENABLE_DEV_IDENTITY=false
DEV_USER_ROLE=viewer
DEV_USER_PRINTER_IDS=
ENABLE_UNSAFE_DEVELOPMENT_TOOLS=false
ENABLE_TEST_ENDPOINTS=false

# Default printer settings used when creating/configuring printers.
PRINTER_IP=192.168.100.2
PRINTER_PORT=3100
EMULATOR_HOST=127.0.0.1
EMULATOR_PORT=3100

# Printer command and polling timing.
COMMAND_TIMEOUT_MS=5000
BETWEEN_COMMAND_DELAY_MS=150
BETWEEN_CODER_DELAY_MS=300
POLL_INTERVAL_MS=5000
# Legacy alias for POLL_INTERVAL_MS. Prefer POLL_INTERVAL_MS for new config.
STATUS_POLL_MS=
STALE_AFTER_MS=15000
OFFLINE_AFTER_FAILURES=3
SSE_HEARTBEAT_MS=20000

# Printer execution mode.
# local = main server talks directly to printers.
# agent = main server queues work and printer-agent.js talks to printers.
PRINTER_EXECUTION_MODE=local

# Main server agent authentication. Use either PRINTER_AGENT_CREDENTIALS or
# the single-agent PRINTER_AGENT_ID / PRINTER_AGENT_TOKEN pair.
PRINTER_AGENT_CREDENTIALS=
PRINTER_AGENT_ID=printer-agent-1
PRINTER_AGENT_TOKEN=
PRINTER_AGENT_PRINTER_IDS=*
REQUIRE_AGENT_MTLS=false

# Fault history and diagnostics.
FAULT_HISTORY_LIMIT=1000
FAULT_HISTORY_PATH=
NGPCL_TRACE=false

# Legacy JSON user path. Normal runtime users are stored in SQLite.
USERS_PATH=

# Local seed command overrides for npm run seed:releases.
SEED_MASTER_CODE=
SEED_COMPLETED_RELEASES=100
SEED_RELEASED_RELEASES=15

# Printer agent process. Used by npm run start:agent.
MAIN_SERVER_URL=
PRINTER_AGENT_STATE=data/printer-agent-state.json
PRINTER_AGENT_POLL_MS=500
PRINTER_AGENT_HEARTBEAT_MS=15000
PRINTER_AGENT_CONFIG_REFRESH_MS=30000
PRINTER_AGENT_CA_CERT=
PRINTER_AGENT_CLIENT_CERT=
PRINTER_AGENT_CLIENT_KEY=
PRINTER_AGENT_ALLOW_HTTP=false
