NODE_ENV=production
PORT=8080

# Important: main server queues printer jobs only.
# It must NOT connect directly to the printer.
PRINTER_EXECUTION_MODE=agent

# Web login/session
SESSION_SECRET=45tfrebnbgfgrhgfHGFHgfNBnHgfgbfg

# First install only - remove after admin account is created
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=admin123

# For reverse proxy setups.
# For direct local testing this can usually stay false or be omitted.
TRUST_PROXY=false

# For local HTTP testing only
REQUIRE_AGENT_MTLS=false

# Agent credentials.
# Must match the agent .env exactly.
PRINTER_AGENT_CREDENTIALS={"packaging-agent-1":{"token":"UDiDxTyK7t3GZOffqeAuXg9OUdlqGKUg","printerIds":["coder-1"]}}


PRINTER_AGENT_TOKEN=UDiDxTyK7t3GZOffqeAuXg9OUdlqGKUg

NODE_ENV=production

MAIN_SERVER_URL=http://127.0.0.1:8080

PRINTER_AGENT_ID=packaging-agent-1

PRINTER_AGENT_CONFIG=printers/printers.json
PRINTER_AGENT_STATE=.agents/state.json

PRINTER_AGENT_POLL_MS=500
PRINTER_AGENT_HEARTBEAT_MS=15000
COMMAND_TIMEOUT_MS=5000
BETWEEN_COMMAND_DELAY_MS=150

PRINTER_AGENT_ALLOW_HTTP=true