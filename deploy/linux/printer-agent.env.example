# /etc/videojet-printer-agent/agent.env
# Printer-agent production/test deployment environment.
# Copy this file, fill secrets, then keep it readable only by root and the vmm-agent service account.

NODE_ENV=production
MAIN_SERVER_URL=https://vmm-agent.site.internal
PRINTER_AGENT_ID=packaging-agent-1
PRINTER_AGENT_TOKEN=replace-with-same-long-random-agent-token-as-main-server
PRINTER_AGENT_STATE=/var/lib/videojet-printer-agent/state.json

# mTLS files copied from tls/create-vmm-tls.ps1 output.
PRINTER_AGENT_CA_CERT=/etc/videojet-printer-agent/tls/site-ca.pem
PRINTER_AGENT_CLIENT_CERT=/etc/videojet-printer-agent/tls/agent.crt
PRINTER_AGENT_CLIENT_KEY=/etc/videojet-printer-agent/tls/agent.key

PRINTER_AGENT_POLL_MS=500
PRINTER_AGENT_HEARTBEAT_MS=15000
PRINTER_AGENT_CONFIG_REFRESH_MS=30000
COMMAND_TIMEOUT_MS=5000
BETWEEN_COMMAND_DELAY_MS=150

# Never enable this in production. It exists only for local HTTP-only development.
PRINTER_AGENT_ALLOW_HTTP=false
