# /etc/videojet-message-manager/main.env
# Main server production/test deployment environment.
# Copy this file, fill secrets, then keep it readable only by root and the vmm service account.

NODE_ENV=production
PORT=8080
DB_PATH=data/videojet.db
SESSION_SECRET=replace-with-64-hex-chars-or-long-random-secret
TRUST_PROXY=true

# Remove bootstrap credentials after the first admin has signed in and changed password.
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=replace-with-temporary-strong-password
BOOTSTRAP_ADMIN_DISPLAY_NAME=Admin
BOOTSTRAP_ADMIN_EMAIL=

# Agent execution. The main server queues jobs; it must not open printer TCP connections.
PRINTER_EXECUTION_MODE=agent
REQUIRE_AGENT_MTLS=true
PRINTER_AGENT_CREDENTIALS={"packaging-agent-1":{"token":"replace-with-long-random-agent-token","printerIds":["coder-1","coder-2","coder-3"]}}

# Email dry-run. Switch to smtp only after the deployment test works.
EMAIL_ENABLED=false
EMAIL_TRANSPORT=log
EMAIL_FROM=
EMAIL_BASE_URL=https://vmm.site.internal
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_REQUIRE_TLS=true
SMTP_USER=
SMTP_PASS=
SMTP_TIMEOUT_MS=10000

# Runtime timing.
COMMAND_TIMEOUT_MS=5000
BETWEEN_COMMAND_DELAY_MS=150
BETWEEN_CODER_DELAY_MS=300
POLL_INTERVAL_MS=5000
STALE_AFTER_MS=15000
OFFLINE_AFTER_FAILURES=3
SSE_HEARTBEAT_MS=20000

# Keep disabled in production/test deployment unless specifically needed.
ENABLE_DEV_IDENTITY=false
ENABLE_UNSAFE_DEVELOPMENT_TOOLS=false
ENABLE_TEST_ENDPOINTS=false
